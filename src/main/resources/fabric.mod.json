{
  "schemaVersion": 1,
  "id": "zenithclient",
  "version": "${version}",
  "name": "ZenithClient",
  "description": "ZenithClient is a client-side Fabric utility mod with visual overlays, movement tools, combat assists, HUD options, X-Ray, trajectories, and configurable ESP.",
  "authors": ["catchallcat5382"],
  "contact": {
    "sources": "https://github.com/Catchallcat5382/ZenithClient"
  },
  "license": "MIT",
  "icon": "assets/zenithclient/icon.png",
  "environment": "client",
  "mixins": ["zenithclient.mixins.json"],
  "entrypoints": {
    "client": ["com.zenithclient.client.ZenithClient"],
    "modmenu": ["com.zenithclient.client.ZenithModMenu"]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
